# Default: normalize line endings to LF in the repository
* text=auto eol=lf

# F# sources are LF. F# is whitespace-significant and tab-hostile; keep them LF
# so the compiler never sees CRLF- or tab-rewritten indentation.
*.fs   text eol=lf
*.fsi  text eol=lf
*.fsx  text eol=lf

# Windows batch files must have CRLF — CMD will not parse them otherwise
*.cmd  text eol=crlf
*.bat  text eol=crlf

# PowerShell scripts work with both, but keep LF consistent with the repo default
*.ps1  text eol=lf
*.psm1 text eol=lf
*.psd1 text eol=lf
