<?xml version="1.0" encoding="utf-8"?>
<configuration>
	<packageSources>
		<clear />
		<add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
		<!-- Test-only local feed for ProcessKit.Testing, vendored under local-packages/.
		     ProcessKit 2.0.0 (the runtime package) is on nuget.org, but its split-out
		     ProcessKit.Testing doubles (ScriptedRunner/Reply) are not published yet, so the
		     .nupkg is vendored here. It is a TEST dependency only — it never flows into the
		     published VcsToolkit packages — so this does not affect consumers. Remove this feed
		     and vendored file once ProcessKit.Testing is published to nuget.org. -->
		<add key="local" value="local-packages" />
	</packageSources>
</configuration>
