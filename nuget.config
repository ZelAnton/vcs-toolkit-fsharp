<?xml version="1.0" encoding="utf-8"?>
<configuration>
	<packageSources>
		<clear />
		<add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
		<!-- Local feed for the ProcessKit build vendored under local-packages/.
		     nuget.org currently publishes ProcessKit up to 1.3.2; the 2.0.0 API this
		     toolkit targets ships only from the sibling ProcessKit-fSharp solution, so
		     its .nupkg is vendored here to keep the repo self-contained. -->
		<add key="local" value="local-packages" />
	</packageSources>
</configuration>
