<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<IsPackable>false</IsPackable>
		<AssemblySearchPaths>$(AssemblySearchPaths);$(WatchDir)bin\$(Configuration)\$(TargetFramework);$(CoreDir)bin\$(Configuration)\$(TargetFramework);$(JjDir)bin\$(Configuration)\$(TargetFramework);$(GitDir)bin\$(Configuration)\$(TargetFramework);$(DiffDir)bin\$(Configuration)\$(TargetFramework);$(CliSupportDir)bin\$(Configuration)\$(TargetFramework)</AssemblySearchPaths>
	</PropertyGroup>

	<ItemGroup>
		<Compile Include="WatchTests.fs" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="FSharp.Core" />
		<PackageReference Include="Microsoft.NET.Test.Sdk" />
		<PackageReference Include="NUnit" />
		<PackageReference Include="NUnit3TestAdapter" />
		<PackageReference Include="ProcessKit" />
		<PackageReference Include="ProcessKit.Testing" />
	</ItemGroup>

	<ItemGroup>
		<Reference Include="VcsToolkit.Watch" />
		<Reference Include="VcsToolkit.Core" />
		<Reference Include="VcsToolkit.Jj" />
		<Reference Include="VcsToolkit.Git" />
		<Reference Include="VcsToolkit.Diff" />
		<Reference Include="VcsToolkit.CliSupport" />
	</ItemGroup>

</Project>
